<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="QUICK TASKS"
            android:textColor="#FFB300"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:alpha="0.6"
            android:text="AOD"
            android:textColor="#F5EFEB"
            android:textSize="12sp"
            android:textStyle="normal" />
    </RelativeLayout>

    <!-- Empty State -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="No pinned tasks. Tap below to create or pin a list."
        android:textColor="#9C8E85"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Task Rows container -->
    <LinearLayout
        android:id="@+id/widget_tasks_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/widget_task_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_task_check_1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:id="@+id/widget_task_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="20dp"
                android:layout_toEndOf="@id/widget_task_check_1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task 1 description"
                android:textColor="#E6E1E5"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/widget_task_priority_1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/priority_dot_medium" />
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/widget_task_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_task_check_2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:id="@+id/widget_task_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="20dp"
                android:layout_toEndOf="@id/widget_task_check_2"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task 2 description"
                android:textColor="#E6E1E5"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/widget_task_priority_2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/priority_dot_medium" />
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/widget_task_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_task_check_3"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:id="@+id/widget_task_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="20dp"
                android:layout_toEndOf="@id/widget_task_check_3"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task 3 description"
                android:textColor="#E6E1E5"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/widget_task_priority_3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/priority_dot_medium" />
        </RelativeLayout>

        <!-- Row 4 -->
        <RelativeLayout
            android:id="@+id/widget_task_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_task_check_4"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:id="@+id/widget_task_title_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="20dp"
                android:layout_toEndOf="@id/widget_task_check_4"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task 4 description"
                android:textColor="#E6E1E5"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/widget_task_priority_4"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/priority_dot_medium" />
        </RelativeLayout>

        <!-- Row 5 -->
        <RelativeLayout
            android:id="@+id/widget_task_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <ImageView
                android:id="@+id/widget_task_check_5"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:id="@+id/widget_task_title_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="20dp"
                android:layout_toEndOf="@id/widget_task_check_5"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task 5 description"
                android:textColor="#E6E1E5"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/widget_task_priority_5"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/priority_dot_medium" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Bottom interactive Quick Action Button -->
    <LinearLayout
        android:id="@+id/widget_add_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add New Task"
            android:textColor="#3E2723"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
